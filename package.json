{
  "name": "codeatlas",
  "version": "1.0.50",
  "type": "module",
  "description": "CodeAtlas context graph database and MCP server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "bin": {
    "codeatlas-mcp": "./dist/MCP/server.js"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "mcp": "tsc && chmod 755 dist/MCP/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "elysia": "latest",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "bun-types": "latest",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}